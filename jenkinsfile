pipeline {
  agent any

  environment {
    S3_BUCKET = "frontend-static-f31323b8"
    AWS_REGION = "us-east-1"
  }

  stages {
    stage('Checkout') {
      steps {
        git 'https://github.com/barik-bijayalaxmi/Frontend-DevOps-.git'
      }
    }

    stage('Build') {
      steps {
        sh '''
          cd frontend
          npm install
          npm run build
        '''
      }
    }

    stage('Upload to S3') {
      steps {
        sh '''
          aws s3 sync frontend/build s3://$S3_BUCKET --delete
        '''
      }
    }

    stage('Invalidate CloudFront') {
      steps {
        sh '''
          aws cloudfront create-invalidation \
          --distribution-id E1II3MN5PP1CLD \
          --paths "/*"
        '''
      }
    }
  }
}
